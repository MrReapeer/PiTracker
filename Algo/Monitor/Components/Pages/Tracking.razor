@page "/"
@rendermode InteractiveServer
@inject VisionStateService Vision
@inject TrackerWorker Worker
@inject IJSRuntime JS
@implements IDisposable

<PageTitle>Tracking – PiTracker Monitor</PageTitle>

<div class="d-flex flex-column" style="height: 100%; width: 100%; background: #050806;">

    @* ── Top toolbar ──────────────────────────────────────────────────── *@
    <MudPaper Class="pa-2 px-4 d-flex align-center flex-shrink-0" Elevation="4" Style="background: #0c120e; z-index: 10;">
        <MudText Typo="Typo.h6" Color="Color.Primary" Class="mr-6" Style="font-family: monospace;"><b>TRACKING</b>_UPLINK</MudText>

        @* Mode toggle *@
        <MudButtonGroup Variant="Variant.Outlined" Size="Size.Small" Class="mr-4">
            <MudButton Color="@(Vision.Mode == OperationMode.Demo ? Color.Primary : Color.Default)"
                       OnClick="@(() => SetMode(OperationMode.Demo))">Demo</MudButton>
            <MudButton Color="@(Vision.Mode == OperationMode.Live ? Color.Success : Color.Default)"
                       OnClick="@(() => SetMode(OperationMode.Live))">Live</MudButton>
        </MudButtonGroup>

        @* Lock controls *@
        <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large"
                   StartIcon="@Icons.Material.Filled.GpsFixed"
                   Disabled="@(!_hasClick)"
                   OnClick="SendLock" Class="mr-2 px-6" Style="font-weight: 900; letter-spacing: 2px;">LOCK</MudButton>

        <MudButton Variant="Variant.Outlined" Color="Color.Error" Size="Size.Medium"
                   StartIcon="@Icons.Material.Filled.GpsOff"
                   OnClick="@(() => Vision.ClearLock())">Clear</MudButton>

        <MudSpacer />

        <MudButton Variant="Variant.Text" Color="Color.Secondary" StartIcon="@Icons.Material.Filled.Fullscreen"
                   OnClick="RequestFullscreen">Fullscreen</MudButton>

        @* FPS badge *@
        <MudChip T="string" Size="Size.Small" Color="Color.Dark" Class="ml-4" Style="font-family: monospace;">@($"{Vision.FpsActual:F1} fps")</MudChip>
    </MudPaper>

    @* ── Camera error banner ──────────────────────────────────────────── *@
    @if (!Vision.IsCameraAvailable)
    {
        <MudAlert Severity="Severity.Error" Class="m-2 flex-shrink-0" Icon="@Icons.Material.Filled.VideocamOff">
            @Vision.CameraError
        </MudAlert>
    }

    @* ── Stream image (Centered) ──────────────────────────────────────── *@
    <div style="flex-grow: 1; position: relative; display: flex; justify-content: center; align-items: center; overflow: hidden; background: #000;">
        @if (!string.IsNullOrEmpty(Vision.LatestFrameBase64))
        {
            <div style="position: relative; display: inline-block;">
                <img id="stream-img"
                     src="@Vision.LatestFrameBase64"
                     style="max-width: 100vw; max-height: calc(100vh - 150px); width: auto; height: auto; display: block; cursor: crosshair; user-select: none;"
                     @onclick="OnImageClick" />

                @* Click reticle overlay (Big crosshair) *@
                @if (_hasClick)
                {
                    <div style="position: absolute;
                                left: calc(@(_clickRatioX * 100)%);
                                top: calc(@(_clickRatioY * 100)%);
                                pointer-events: none;
                                transform: translate(-50%, -50%);
                                width: 80px; height: 80px;">
                        @* Vertical line *@
                        <div style="position: absolute; left: 39px; top: 0; width: 2px; height: 100%; background: rgba(0, 230, 118, 0.8); box-shadow: 0 0 4px #00e676;"></div>
                        @* Horizontal line *@
                        <div style="position: absolute; left: 0; top: 39px; width: 100%; height: 2px; background: rgba(0, 230, 118, 0.8); box-shadow: 0 0 4px #00e676;"></div>
                    </div>
                }
            </div>
        }
        else
        {
            <div style="display: flex; flex-direction: column; align-items: center;">
                <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Large" Class="mb-4" />
                <MudText Color="Color.Primary" Style="font-family: monospace; letter-spacing: 2px;">WAITING_FOR_SIGNAL...</MudText>
            </div>
        }
    </div>

    @* ── Status bar ───────────────────────────────────────────────────── *@
    @if (Vision.CurrentLock is { } lp && lp.IsLocked)
    {
        <MudPaper Class="pa-2 px-4 flex-shrink-0" Elevation="4" Style="background: #0c120e; border-top: 1px solid #1b5e20;">
            <MudGrid Spacing="1">
                <MudItem xs="6" sm="3">
                    <MudText Typo="Typo.caption" Color="Color.Secondary" Style="font-family: monospace;">POS_X // POS_Y</MudText>
                    <MudText Typo="Typo.body2" Style="font-family: monospace; color: #00e676;">@lp.X.ToString("F1") // @lp.Y.ToString("F1")</MudText>
                </MudItem>
                <MudItem xs="6" sm="3">
                    <MudText Typo="Typo.caption" Color="Color.Secondary" Style="font-family: monospace;">WID // HGT</MudText>
                    <MudText Typo="Typo.body2" Style="font-family: monospace; color: #00e676;">@lp.W.ToString("F1") // @lp.H.ToString("F1")</MudText>
                </MudItem>
                <MudItem xs="6" sm="3">
                    <MudText Typo="Typo.caption" Color="Color.Secondary" Style="font-family: monospace;">VEL_X // VEL_Y</MudText>
                    <MudText Typo="Typo.body2" Style="font-family: monospace; color: #00e676;">@lp.dX.ToString("F1") // @lp.dY.ToString("F1")</MudText>
                </MudItem>
                <MudItem xs="6" sm="3">
                    <MudText Typo="Typo.caption" Color="Color.Secondary" Style="font-family: monospace;">CONFIDENCE</MudText>
                    <MudProgressLinear Color="@ConfColor(lp.Confidence)" Value="@(lp.Confidence * 100)" Rounded="true" Class="my-1" />
                    <MudText Typo="Typo.body2" Style="font-family: monospace;">@lp.Confidence.ToString("P0")</MudText>
                </MudItem>
                @if (!string.IsNullOrEmpty(lp.DebugInfo))
                {
                    <MudItem xs="12">
                        <MudText Typo="Typo.caption" Color="Color.Secondary" Style="font-family: monospace;">DBUG_SYS_LOG</MudText>
                        <MudText Typo="Typo.caption" Style="font-family: monospace; color: #81c784;">> @lp.DebugInfo</MudText>
                    </MudItem>
                }
            </MudGrid>
        </MudPaper>
    }
    else
    {
        <MudPaper Class="pa-1 text-center flex-shrink-0" Elevation="0" Style="background: #050806;">
            <MudText Typo="Typo.caption" Color="Color.Secondary" Style="font-family: monospace; letter-spacing: 1px;">
                > SYSTEM IDLE: SELECT TARGET IN VIEWPORT AND ENGAGE LOCK
            </MudText>
        </MudPaper>
    }
</div>

@code {
    // ── Click state ───────────────────────────────────────────────────────────
    private bool _hasClick = true; // Auto-enable click for the center initially
    private double _clickRatioX = 0.5; // Default center X
    private double _clickRatioY = 0.5; // Default center Y

    // ── Frame dimensions tracked from camera ──────────────────────────────────
    private int _frameWidth  => Vision.NativeWidth;
    private int _frameHeight => Vision.NativeHeight;

    // ── Lifecycle ─────────────────────────────────────────────────────────────
    protected override void OnInitialized()
    {
        Vision.OnFrameUpdate += OnFrameArrived;
    }

    public void Dispose()
    {
        Vision.OnFrameUpdate -= OnFrameArrived;
    }

    private void OnFrameArrived()
    {
        InvokeAsync(StateHasChanged);
    }

    // ── Fullscreen Request ────────────────────────────────────────────────────
    private async Task RequestFullscreen()
    {
        // Calling our registered JS helper to pop the browser window to full screen.
        await JS.InvokeVoidAsync("trackingHelper.toggleFullscreen", null);
    }

    // ── Click-to-aim ──────────────────────────────────────────────────────────
    private async Task OnImageClick(MouseEventArgs e)
    {
        // Use JS interop to get ratio within the img element (handles CSS scaling)
        var result = await JS.InvokeAsync<ClickRatio>("trackingHelper.getClickRatio",
            "stream-img", e.ClientX, e.ClientY);
        _clickRatioX = result.X;
        _clickRatioY = result.Y;
        _hasClick = true;
        StateHasChanged();
    }

    private void SendLock()
    {
        if (_hasClick)
            Vision.ProcessLockRequest(_clickRatioX, _clickRatioY);
    }

    private void SetMode(OperationMode mode)
    {
        Vision.Mode = mode;
        Vision.ClearLock();
    }

    private Color ConfColor(double conf) =>
        conf >= 0.7 ? Color.Success : conf >= 0.4 ? Color.Warning : Color.Error;

    // ── JS interop DTOs ───────────────────────────────────────────────────────
    private class ClickRatio { public double X { get; set; } public double Y { get; set; } }
}
